# ============================================================
# Your AIOS Workspace — Environment Configuration
# ============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
#
# NEVER commit .env to version control — it contains your secrets.
# The .gitignore file already prevents this, but be careful.
#
# As you install more AIOS modules, each one will tell you which
# API keys to add here. This file grows with your workspace.
# ============================================================

# --- Core AI APIs (recommended — used by most modules) ---
# Get at: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Get at: platform.openai.com/api-keys
OPENAI_API_KEY=

# Get at: aistudio.google.com/apikey
GEMINI_API_KEY=

# --- DataOS (added by DataOS module) ---
# STRIPE_API_KEY_MAIN=
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=
# GA4_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-service-account.json
# GOOGLE_SHEET_ID=
# BITLY_ACCESS_TOKEN=

# --- IntelOS (added by IntelOS module) ---
# FIREFLIES_API_KEY=
# FATHOM_API_KEY=
# SLACK_TOKEN_MAIN=
